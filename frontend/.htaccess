# ── Cross-Origin Isolation headers for Wasmer / SharedArrayBuffer ───────────
#
# The Wasmer SDK (used by Clang.wasm) requires SharedArrayBuffer, which is
# only available when the page is "cross-origin isolated". These two headers
# enable that isolation.
#
# References:
#   https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/SharedArrayBuffer#security_requirements
#   https://wasmer.io/posts/running-cpp-in-browser
#
<IfModule mod_headers.c>
    Header always set Cross-Origin-Opener-Policy "same-origin"
    Header always set Cross-Origin-Embedder-Policy "require-corp"
</IfModule>
